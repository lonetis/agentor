{
  "name": "agentor-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:api": "npx playwright test --project=api",
    "test:ui": "npx playwright test --project=ui",
    "test:headed": "npx playwright test --project=ui --headed",
    "test:debug": "npx playwright test --project=ui --headed --slowmo 200 --workers=1",
    "test:trace": "npx playwright test --trace on",
    "test:report": "npx playwright show-report",
    "test:docker": "docker compose -f ../docker-compose.tests.yml run --rm test-runner",
    "test:docker:api": "docker compose -f ../docker-compose.tests.yml run --rm test-runner --project=api",
    "test:docker:ui": "docker compose -f ../docker-compose.tests.yml run --rm test-runner --project=ui",
    "test:docker:clean": "docker compose -f ../docker-compose.tests.yml down -v --remove-orphans && docker volume rm agentor-test-runner-docker 2>/dev/null || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "ssh2": "^1.17.0",
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  }
}
