# =============================================================================
# Agent Orchestrator (Agentor) - Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# The orchestrator always runs inside Docker (both dev and production).
# See docker-compose.prod.yml (production) and docker-compose.dev.yml (development).

# --- OAuth Credentials ---
# OAuth/subscription credentials are stored as JSON files in .cred/.
# Copy from .cred.example/:  cp -r .cred.example .cred
# See .cred.example/README for details.

# --- Claude API Key (optional, can configure inside container) ---

# Anthropic API key (pay-as-you-go).
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# --- OpenAI / Codex API Key (optional, can configure inside container) ---

# OpenAI API key (pay-as-you-go).
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# --- Google Gemini API Key (optional, can configure inside container) ---

# Gemini API key (pay-as-you-go).
# Get from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# --- GitHub ---

# GitHub personal access token for cloning private repos and gh CLI auth.
# Get from: https://github.com/settings/tokens
# Needs 'repo' scope for private repositories, 'read:packages' for GHCR images,
# and 'read:org' if cloning from organization repositories.
# Used by `gh auth login` inside workers for git credential management.
# GITHUB_TOKEN=

# --- Worker Images ---

# Prefix prepended to worker image names when pulling (e.g. "ghcr.io/lonetis/").
# Leave empty for locally built images (development).
# docker-compose.prod.yml sets this automatically.
# WORKER_IMAGE_PREFIX=

# --- Orchestrator ---

# Persistent data directory inside the container (default: /data)
# DATA_DIR=/data

# Docker network name shared by orchestrator and workers (default: agentor-net)
# DOCKER_NETWORK=agentor-net

# Worker container name prefix (default: agentor-worker)
# CONTAINER_PREFIX=agentor-worker

# Worker Docker image name (default: agentor-worker:latest)
# In production, WORKER_IMAGE_PREFIX is prepended.
# WORKER_IMAGE=agentor-worker:latest

# Orchestrator Docker image name (default: agentor-orchestrator:latest)
# Used by the update checker to compare local vs remote digests.
# In production, WORKER_IMAGE_PREFIX is prepended.
# ORCHESTRATOR_IMAGE=agentor-orchestrator:latest

# Default CPU limit per worker in cores (default: no limit)
# DEFAULT_CPU_LIMIT=

# Default memory limit per worker (default: no limit)
# Supports: b, k, m, g suffixes (e.g. 4g, 512m)
# DEFAULT_MEMORY_LIMIT=

# --- Network Firewall ---

# Comma-separated list of domains allowed in "Package managers" network mode.
# Overrides the built-in defaults (~98 domains covering npm, PyPI, crates.io,
# Go modules, Maven, APT, Homebrew, Docker Hub, GitHub, and more).
# Supports * wildcards (e.g. *.amazonaws.com).
# Leave unset to use built-in defaults.
# PACKAGE_MANAGER_DOMAINS=registry.npmjs.org,pypi.org,crates.io,proxy.golang.org

# --- Port Mapper ---

# Docker image for the port mapper container (default: agentor-mapper:latest)
# In production, WORKER_IMAGE_PREFIX is prepended (e.g. ghcr.io/lonetis/agentor-mapper:latest)
# MAPPER_IMAGE=agentor-mapper:latest

# Named Docker volume for the shared data directory.
# The mapper container mounts this read-only to access port-mappings.json.
# Both docker-compose.dev.yml and docker-compose.prod.yml set this automatically.
# DATA_VOLUME=agentor-data

# --- Domain Mapping (Traefik) ---

# Base domain for domain-based routing via Traefik.
# All subdomains will be routable to worker containers.
# Leave empty to disable domain mapping entirely.
# BASE_DOMAIN=

# Subdomain for the Agentor dashboard.
# When set, the dashboard is accessible at <DASHBOARD_SUBDOMAIN>.<BASE_DOMAIN>.
# Leave empty to not expose the dashboard via domain routing.
# DASHBOARD_SUBDOMAIN=

# Basic auth credentials for the dashboard subdomain.
# Both must be set to enable authentication. Leave empty for no auth.
# DASHBOARD_AUTH_USER=
# DASHBOARD_AUTH_PASSWORD=

# Email address for Let's Encrypt certificate registration.
# Required when BASE_DOMAIN is set. Used for ACME account registration.
# ACME_EMAIL=

# Traefik Docker image (default: traefik:v3)
# TRAEFIK_IMAGE=traefik:v3
