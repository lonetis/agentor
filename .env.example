################################################################################
#                                                                              #
#               Agent Orchestrator (Agentor) — Configuration                   #
#                                                                              #
################################################################################
#
# Copy this file to .env and fill in the values you need:
#     cp .env.example .env
#
# Every variable is commented out and set to its default. Uncomment only the
# ones you want to override. The orchestrator always runs inside Docker — see
# docker-compose.prod.yml (production) and docker-compose.dev.yml (development).
#


# ══════════════════════════════════════════════════════════════════════════════
#   AGENT & GIT CREDENTIALS
# ══════════════════════════════════════════════════════════════════════════════
#
# Agent API keys (Anthropic / OpenAI / Gemini), the Claude Code OAuth token,
# the GitHub token, and any other per-user secrets are configured from the
# dashboard in  Account → API keys & tokens  (sign in, click your name in the
# sidebar footer). Each user gets their own copy — workers inherit the env
# vars of the user who created them, so different users can use different
# subscriptions or API keys on the same installation.
#
# For OAuth subscriptions (Claude Pro/Max, ChatGPT Codex, Gemini Code Assist),
# sign in once inside any of your workers:
#   • Claude:  `claude`  →  `/login`
#   • Codex:   `codex login --device-auth`
#   • Gemini:  `gemini`  →  `/auth`
# Tokens are stored per-user under `<DATA_DIR>/users/<userId>/credentials/`
# and shared across all of that user's workers.


# ══════════════════════════════════════════════════════════════════════════════
#   DASHBOARD AUTHENTICATION (better-auth)
# ══════════════════════════════════════════════════════════════════════════════

# Secret key for session cookie signing. Required in production.
# Generate with:  openssl rand -hex 32
# If empty, a random secret is auto-generated on first run and persisted to
# <DATA_DIR>/.auth-secret so sessions survive restarts.
# BETTER_AUTH_SECRET=

# Canonical base URL the dashboard is served from. Used by better-auth for
# cookie domain and default trusted origin.
# Default: http://localhost:3000
# Override when deploying behind a reverse proxy.
# BETTER_AUTH_URL=https://agentor.example.com

# Additional comma-separated origins to trust for CSRF/Origin checks on auth
# requests. Trusted automatically (no need to list here):
#   - http://localhost:3000  and  http://127.0.0.1:3000
#   - BETTER_AUTH_URL
#   - https://<DASHBOARD_SUBDOMAIN>.<DASHBOARD_BASE_DOMAIN>
# Use this for any extra hostnames (e.g. a second domain pointing at the same
# instance).
# BETTER_AUTH_TRUSTED_ORIGINS=https://alt.example.com,https://dash.internal

# WebAuthn Relying Party ID for passkey authentication.
# Passkeys require a stable HTTPS origin, so they are only enabled when both
# DASHBOARD_SUBDOMAIN and DASHBOARD_BASE_DOMAIN are set (dashboard served over
# Traefik). When enabled, rpID defaults to
#   <DASHBOARD_SUBDOMAIN>.<DASHBOARD_BASE_DOMAIN>
# Override to a parent domain (e.g. `agentor.example.com`) if you want one
# passkey to work across multiple subdomains of the same parent.
# BETTER_AUTH_RP_ID=agentor.example.com


# ══════════════════════════════════════════════════════════════════════════════
#   ORCHESTRATOR RUNTIME
# ══════════════════════════════════════════════════════════════════════════════
#
# Storage mode is auto-detected from how /data is mounted in the compose file:
#     Volume mode:     agentor-data:/data   (Docker named volumes)
#     Directory mode:  ./data:/data         (host directories under ./data/)
# No env var needed — switch by changing the volume line in docker-compose.*.yml.
#

# Persistent data directory inside the container.
# DATA_DIR=/data

# Docker network shared by orchestrator and workers.
# DOCKER_NETWORK=agentor-net

# Worker container name prefix (e.g. `agentor-worker-happy-panda`).
# CONTAINER_PREFIX=agentor-worker

# Worker Docker image name. WORKER_IMAGE_PREFIX is prepended in production.
# WORKER_IMAGE=agentor-worker:latest

# Orchestrator Docker image name. Used by the update checker to compare local
# vs remote digests. WORKER_IMAGE_PREFIX is prepended in production.
# ORCHESTRATOR_IMAGE=agentor-orchestrator:latest

# Prefix prepended to image names when pulling from a registry (e.g.
# `ghcr.io/lonetis/`). Leave empty for locally built images.
# docker-compose.prod.yml sets this automatically.
# WORKER_IMAGE_PREFIX=

# Default CPU limit per worker in cores (empty = unlimited).
# DEFAULT_CPU_LIMIT=

# Default memory limit per worker. Supports b, k, m, g suffixes (e.g. 4g, 512m).
# Empty = unlimited.
# DEFAULT_MEMORY_LIMIT=

# [Deprecated] Named Docker volume for the shared data directory.
# Auto-detected from the /data mount type since v2. Only used as a fallback
# if container self-inspection fails.
# DATA_VOLUME=agentor-data


# ══════════════════════════════════════════════════════════════════════════════
#   LOGGING
# ══════════════════════════════════════════════════════════════════════════════

# Minimum log level:  debug | info | warn | error
# LOG_LEVEL=info

# Maximum log file size before rotation. Supports k, m, g suffixes.
# LOG_MAX_SIZE=50m

# Number of rotated log files to keep per log category.
# LOG_MAX_FILES=5


# ══════════════════════════════════════════════════════════════════════════════
#   NETWORK FIREWALL
# ══════════════════════════════════════════════════════════════════════════════

# Comma-separated list of domains allowed in "Package managers" network mode.
# Overrides the built-in defaults (~98 domains covering npm, PyPI, crates.io,
# Go modules, Maven, APT, Homebrew, Docker Hub, GitHub, and more).
# Supports * wildcards (e.g. `*.amazonaws.com`).
# Leave unset to use built-in defaults.
# PACKAGE_MANAGER_DOMAINS=registry.npmjs.org,pypi.org,crates.io,proxy.golang.org


# ══════════════════════════════════════════════════════════════════════════════
#   DOMAIN ROUTING (Traefik)
# ══════════════════════════════════════════════════════════════════════════════
#
# Domain-based routing for workers and the dashboard, backed by a Traefik
# reverse proxy. Optional — port mappings work without this.
#

# Comma-separated base domain(s) for routing. Each entry controls the TLS
# challenge type used for that domain:
#
#     domain.com                    HTTP only, no TLS
#     domain.com:http               HTTP-01 ACME       (needs port 80 public)
#     domain.com:dns:<provider>     DNS-01 ACME        (enables *.domain.com)
#     domain.com:selfsigned         Self-signed CA     (no external deps)
#
# Self-signed uses a locally generated CA that must be trusted in the browser.
# Download the CA cert from the dashboard (Domain Mappings panel) or via
#   GET /api/domain-mapper/ca-cert
#
# Challenge types can be mixed freely:
#   BASE_DOMAINS=a.com:dns:cloudflare,b.com:http,c.com,d.com:selfsigned
#
# Leave empty to disable domain mapping entirely.
# BASE_DOMAINS=

# Subdomain for the Agentor dashboard itself.
# When set, the dashboard is served at <DASHBOARD_SUBDOMAIN>.<DASHBOARD_BASE_DOMAIN>.
# Leave empty to not expose the dashboard via domain routing.
# DASHBOARD_SUBDOMAIN=

# Which base domain to use for the dashboard. Must be one of the domains in
# BASE_DOMAINS. Defaults to the first BASE_DOMAINS entry.
# DASHBOARD_BASE_DOMAIN=

# Basic auth credentials for the dashboard subdomain (layered on top of the
# app's own auth). Both must be set to enable. Leave empty for no auth.
# DASHBOARD_AUTH_USER=
# DASHBOARD_AUTH_PASSWORD=

# Email address for Let's Encrypt ACME account registration.
# Required when using :http or :dns: challenge types. Not needed for :selfsigned.
# ACME_EMAIL=

# Traefik Docker image.
# TRAEFIK_IMAGE=traefik:v3


# ══════════════════════════════════════════════════════════════════════════════
#   DNS-01 CHALLENGE PROVIDERS
# ══════════════════════════════════════════════════════════════════════════════
#
# For each DNS provider used in BASE_DOMAINS (:dns:<provider>), configure
# authentication via env vars forwarded to the Traefik container.
#
#   Pattern:      ACME_DNS_<PROVIDER>_VARS lists env var names to forward.
#                 (Provider name is uppercased; hyphens become underscores.)
#   Providers:    https://doc.traefik.io/traefik/https/acme/#providers
#   Auth vars:    https://go-acme.github.io/lego/dns/
#

# ── Cloudflare ────────────────────────────────────────────────────────────────
# ACME_DNS_CLOUDFLARE_VARS=CF_DNS_API_TOKEN
# CF_DNS_API_TOKEN=your-cloudflare-api-token

# ── AWS Route53 ───────────────────────────────────────────────────────────────
# ACME_DNS_ROUTE53_VARS=AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY,AWS_REGION
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1

# ── Optional per-provider tuning ──────────────────────────────────────────────
# ACME_DNS_CLOUDFLARE_DELAY=10                         # seconds before DNS check
# ACME_DNS_CLOUDFLARE_RESOLVERS=1.1.1.1:53,8.8.8.8:53  # verification resolvers
