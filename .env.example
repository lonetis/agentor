# =============================================================================
# Agent Orchestrator (Agentor) - Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# The orchestrator always runs inside Docker (both dev and production).
# See docker-compose.prod.yml (production) and docker-compose.dev.yml (development).

# --- OAuth Credentials ---
# OAuth/subscription credentials are stored as JSON files in .cred/.
# Copy from .cred.example/:  cp -r .cred.example .cred
# See .cred.example/README for details.

# --- Claude Authentication (optional, can configure inside container) ---

# Anthropic API key (pay-as-you-go).
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# Claude Code OAuth setup token (1-year validity, for Pro/Max subscribers).
# Generate on a machine with a browser: claude setup-token
# Alternative to .cred/claude.json OAuth credentials and ANTHROPIC_API_KEY.
# Do not set alongside ANTHROPIC_API_KEY — the setup token takes precedence.
# CLAUDE_CODE_OAUTH_TOKEN=

# --- OpenAI / Codex API Key (optional, can configure inside container) ---

# OpenAI API key (pay-as-you-go).
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# --- Google Gemini API Key (optional, can configure inside container) ---

# Gemini API key (pay-as-you-go).
# Get from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# --- GitHub ---

# GitHub personal access token for cloning private repos and gh CLI auth.
# Get from: https://github.com/settings/tokens
# Needs 'repo' scope for private repositories, 'read:packages' for GHCR images,
# and 'read:org' if cloning from organization repositories.
# Used by `gh auth login` inside workers for git credential management.
# GITHUB_TOKEN=

# --- Worker Images ---

# Prefix prepended to worker image names when pulling (e.g. "ghcr.io/lonetis/").
# Leave empty for locally built images (development).
# docker-compose.prod.yml sets this automatically.
# WORKER_IMAGE_PREFIX=

# --- Authentication ---

# Secret key for session encryption (required for production).
# Generate with: openssl rand -hex 32
# If left empty, a random secret is auto-generated and persisted to
# <DATA_DIR>/.auth-secret on first run.
# BETTER_AUTH_SECRET=

# Canonical base URL the dashboard is served from. Used by better-auth for
# cookie domain and default trusted origin. Leave empty to default to
# http://localhost:3000. Override when deploying behind a reverse proxy.
# BETTER_AUTH_URL=https://agentor.example.com

# Additional comma-separated origins to trust for CSRF/Origin checks on
# auth requests. localhost:3000, 127.0.0.1:3000, BETTER_AUTH_URL, and the
# dashboard subdomain (from DASHBOARD_SUBDOMAIN + DASHBOARD_BASE_DOMAIN) are
# always trusted automatically — use this for any extra hostnames (e.g.
# a second domain pointing at the same instance).
# BETTER_AUTH_TRUSTED_ORIGINS=https://alt.example.com,https://dash.internal

# --- Orchestrator ---

# Storage mode is auto-detected from how /data is mounted in docker-compose:
#   Volume mode:    agentor-data:/data    (Docker named volumes for workspaces/DinD)
#   Directory mode: ./data:/data          (host directories under ./data/)
# No env var needed — switch by changing the volume line in your compose file.

# Persistent data directory inside the container (default: /data)
# DATA_DIR=/data

# Docker network name shared by orchestrator and workers (default: agentor-net)
# DOCKER_NETWORK=agentor-net

# Worker container name prefix (default: agentor-worker)
# CONTAINER_PREFIX=agentor-worker

# Worker Docker image name (default: agentor-worker:latest)
# In production, WORKER_IMAGE_PREFIX is prepended.
# WORKER_IMAGE=agentor-worker:latest

# Orchestrator Docker image name (default: agentor-orchestrator:latest)
# Used by the update checker to compare local vs remote digests.
# In production, WORKER_IMAGE_PREFIX is prepended.
# ORCHESTRATOR_IMAGE=agentor-orchestrator:latest

# Default CPU limit per worker in cores (default: no limit)
# DEFAULT_CPU_LIMIT=

# Default memory limit per worker (default: no limit)
# Supports: b, k, m, g suffixes (e.g. 4g, 512m)
# DEFAULT_MEMORY_LIMIT=

# --- Logging ---

# Minimum log level for all log output (default: info)
# Levels: debug, info, warn, error
# LOG_LEVEL=info

# Maximum log file size before rotation (default: 50m)
# Supports: k, m, g suffixes (e.g. 50m, 1g)
# LOG_MAX_SIZE=50m

# Number of rotated log files to keep per log category (default: 5)
# LOG_MAX_FILES=5

# --- Network Firewall ---

# Comma-separated list of domains allowed in "Package managers" network mode.
# Overrides the built-in defaults (~98 domains covering npm, PyPI, crates.io,
# Go modules, Maven, APT, Homebrew, Docker Hub, GitHub, and more).
# Supports * wildcards (e.g. *.amazonaws.com).
# Leave unset to use built-in defaults.
# PACKAGE_MANAGER_DOMAINS=registry.npmjs.org,pypi.org,crates.io,proxy.golang.org

# --- Port Mapper ---

# Docker image for the port mapper container (default: agentor-mapper:latest)
# In production, WORKER_IMAGE_PREFIX is prepended (e.g. ghcr.io/lonetis/agentor-mapper:latest)
# MAPPER_IMAGE=agentor-mapper:latest

# (Deprecated) Named Docker volume for the shared data directory.
# Auto-detected from the /data mount type since v2. Only used as fallback
# if container self-inspection fails.
# DATA_VOLUME=agentor-data

# --- Domain Mapping (Traefik) ---

# Comma-separated base domain(s) for domain-based routing via Traefik.
# Each entry controls the TLS certificate challenge type:
#   domain.com             — HTTP only, no TLS certificate
#   domain.com:http        — HTTP-01 ACME challenge (requires port 80 publicly accessible)
#   domain.com:dns:provider — DNS-01 ACME challenge with named provider (enables wildcard *.domain.com)
#   domain.com:selfsigned  — Self-signed wildcard TLS via a local CA (no external dependencies)
# Self-signed uses a generated CA certificate that must be trusted in the browser.
# Download the CA cert from the dashboard (Domain Mappings panel) or GET /api/domain-mapper/ca-cert.
# Multiple domains with different challenge types can be mixed freely:
#   BASE_DOMAINS=a.com:dns:cloudflare,b.com:http,c.com,d.com:selfsigned
# Leave empty to disable domain mapping entirely.
# BASE_DOMAINS=

# Subdomain for the Agentor dashboard.
# When set, the dashboard is accessible at <DASHBOARD_SUBDOMAIN>.<DASHBOARD_BASE_DOMAIN>.
# Leave empty to not expose the dashboard via domain routing.
# DASHBOARD_SUBDOMAIN=

# Which base domain to use for the dashboard subdomain.
# Must be one of the domains in BASE_DOMAINS.
# Defaults to the first domain in BASE_DOMAINS if not set.
# DASHBOARD_BASE_DOMAIN=

# Basic auth credentials for the dashboard subdomain.
# Both must be set to enable authentication. Leave empty for no auth.
# DASHBOARD_AUTH_USER=
# DASHBOARD_AUTH_PASSWORD=

# Email address for Let's Encrypt certificate registration.
# Required when using :http or :dns: challenge types. Not needed for :selfsigned. Used for ACME account registration.
# ACME_EMAIL=

# Traefik Docker image (default: traefik:v3)
# TRAEFIK_IMAGE=traefik:v3

# --- DNS Challenge Provider Configuration ---
# For each DNS provider used in BASE_DOMAINS, configure authentication via env vars.
# Pattern: ACME_DNS_<PROVIDER>_VARS lists the env var names to forward to Traefik.
# The provider name is uppercased, hyphens become underscores.
# See https://doc.traefik.io/traefik/https/acme/#providers for provider names.
# See https://go-acme.github.io/lego/dns/ for per-provider env var documentation.

# Cloudflare example:
# ACME_DNS_CLOUDFLARE_VARS=CF_DNS_API_TOKEN
# CF_DNS_API_TOKEN=your-cloudflare-api-token

# Route53 example:
# ACME_DNS_ROUTE53_VARS=AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY,AWS_REGION
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1

# Optional per-provider tuning:
# ACME_DNS_CLOUDFLARE_DELAY=10
# ACME_DNS_CLOUDFLARE_RESOLVERS=1.1.1.1:53,8.8.8.8:53
